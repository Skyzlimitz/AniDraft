# apps/realtime — WebSocket server (Fly.io)
#
# Local: every variable has a dev default, so no .env is needed; to override,
# copy to apps/realtime/.env (git-ignored) and run via
# `tsx --env-file=.env src/index.ts`. Production: stored as Fly secrets
# (never committed):
#   fly secrets set DATABASE_URL=... DATABASE_AUTH_TOKEN=... --app anidraft-realtime
#
# Validated at boot by realtimeEnvSchema (packages/shared/src/env.ts).
# Full reference: docs/env-vars.md

# TCP port the HTTP/WebSocket server listens on. Optional (default: 4000);
# Fly sets it via [env] in fly.toml.
PORT=4000

# Turso (libSQL) connection URL. Required in production (Fly secret);
# defaults to a local file DB in development.
DATABASE_URL=file:./dev.db

# Turso auth token. Optional — not needed for file: URLs.
DATABASE_AUTH_TOKEN=
