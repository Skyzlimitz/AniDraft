# apps/cron — Weekly snapshot worker (Fly.io)
#
# Local: every variable has a dev default, so no .env is needed; to override,
# copy to apps/cron/.env (git-ignored) and run via
# `tsx --env-file=.env src/index.ts`. Production: stored as Fly secrets
# (never committed):
#   fly secrets set DATABASE_URL=... DATABASE_AUTH_TOKEN=... --app anidraft-cron
#
# Validated at boot by cronEnvSchema (packages/shared/src/env.ts).
# Full reference: docs/env-vars.md

# Turso (libSQL) connection URL. Passed to createDb() from @anidraft/db when
# the weekly snapshot job runs (#60). Required in production (Fly secret);
# defaults to a local file DB in development.
DATABASE_URL=file:./dev.db

# Turso auth token. Optional — not needed for file: URLs.
DATABASE_AUTH_TOKEN=

# Log verbosity: debug | info | warn | error. Optional (default: info).
LOG_LEVEL=info
