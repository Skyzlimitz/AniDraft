# apps/cron — Weekly snapshot worker
#
# In production these are provided as Fly secrets (never committed):
#   fly secrets set DATABASE_URL=... DATABASE_AUTH_TOKEN=... --app anidraft-cron
# Locally, copy this file to .env and point DATABASE_URL at a local libSQL file.

# Turso (libSQL) connection. Passed to createDb() from @anidraft/db when the
# weekly snapshot job runs (implemented under #60).
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=

# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info
