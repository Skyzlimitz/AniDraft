# AniDraft — web app environment variables
# Copy to .env.local and fill in values. Do NOT commit secrets.

# Auth.js (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical app URL for Auth.js callbacks. Set to http://localhost:3000
# locally; leave unset on Vercel (auto-detected from the deployment).
AUTH_URL=

# Database (Turso) — falls back to a local SQLite file when unset
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=

# Public base URL of the realtime WebSocket server (client-exposed)
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4000

# Set automatically by Vercel in production; leave blank locally.
VERCEL_URL=
