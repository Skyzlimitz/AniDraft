# apps/web — Next.js app (Vercel)
#
# Local: copy to apps/web/.env.local (git-ignored); Next.js loads it
# automatically. Production: set in the Vercel project env (dashboard or
# `vercel env`). Do NOT commit secrets.
#
# Validated at build/boot by webEnvSchema (packages/shared/src/env.ts).
# Full reference: docs/env-vars.md

# Public URL of the realtime WebSocket server. NEXT_PUBLIC_ → inlined into the
# client bundle at build time. Required in production; defaults to
# ws://localhost:4000 in development.
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4000

# Deployment hostname, set automatically by Vercel in production.
# Optional — leave blank locally.
VERCEL_URL=
