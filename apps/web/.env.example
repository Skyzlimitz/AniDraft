# apps/web — Next.js app (Vercel)
#
# Local: copy to apps/web/.env.local (git-ignored); Next.js loads it
# automatically. Production: set in the Vercel project env (dashboard or
# `vercel env`). Do NOT commit secrets.
#
# Validated at build/boot by webEnvSchema (packages/shared/src/env.ts).
# Full reference: docs/env-vars.md

# Auth.js (NextAuth v5) session/token encryption secret. Required in
# production; generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL for Auth.js callbacks. Optional — set to
# http://localhost:3000 locally if needed; leave unset on Vercel
# (auto-detected from the deployment).
AUTH_URL=

# Google OAuth client credentials (Google Cloud Console, issue #21). Callback:
# {origin}/api/auth/callback/google. Captured when the provider is constructed,
# so the build never depends on them — optional at boot. Set them wherever
# Google sign-in should work (Vercel prod + preview, and locally); without them
# the Google button errors.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth client credentials (Discord Developer Portal, issue #22).
# Callback: {origin}/api/auth/callback/discord. Optional at boot, same as the
# Google pair above.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Turso (libSQL) connection for the Auth.js Drizzle adapter. Required in
# production; defaults to a local SQLite file in development.
DATABASE_URL=file:./dev.db

# Turso auth token; not needed for file: URLs.
DATABASE_AUTH_TOKEN=

# Public URL of the realtime WebSocket server. NEXT_PUBLIC_ → inlined into the
# client bundle at build time. Required in production; defaults to
# ws://localhost:4000 in development.
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4000

# Deployment hostname, set automatically by Vercel in production.
# Optional — leave blank locally.
VERCEL_URL=
