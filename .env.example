# AniDraft — Environment Variables
# Copy this file to .env.local and fill in your values.

# Database (Turso)
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=

# Auth (Auth.js / NextAuth)
AUTH_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# AniList (public API, no key needed for read-only)
# ANILIST_API_URL=https://graphql.anilist.co
# Optional bearer token (raises the rate-limit ceiling; read queries work without it).
# Used by @anidraft/anilist's AniListClient (cron + season-pool fetcher).
ANILIST_TOKEN=

# Realtime server
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4000

# Deployment
VERCEL_URL=
FLY_API_TOKEN=
